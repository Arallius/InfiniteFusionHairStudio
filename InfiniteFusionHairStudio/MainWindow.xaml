<Window x:Class="InfiniteFusionHairStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Infinite Fusion Hair Studio"
        WindowState="Maximized"
        MinWidth="1200"
        MinHeight="700">

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ===================================================== -->
        <!-- LEFT COLUMN -->
        <!-- ===================================================== -->

        <ScrollViewer Grid.Column="0"
                      VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="0,0,20,0">

                <TextBlock Text="Replace Hairstyle"
                           FontWeight="Bold"/>

                <ComboBox x:Name="ReplaceHairComboBox"
                          Margin="0,5,0,20"/>

                <TextBlock Text="Custom Hairstyle Slots"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <GroupBox Margin="0,0,0,10">
                    <GroupBox.Header>
                        <RadioButton x:Name="Slot1Selector"
                                     GroupName="ActiveSlot"
                                     Content="Slot 1"
                                     IsChecked="True"/>
                    </GroupBox.Header>

                    <TextBlock Margin="10"
                               Text="Custom Hairstyle 1"/>
                </GroupBox>

                <GroupBox Margin="0,0,0,10">
                    <GroupBox.Header>
                        <RadioButton x:Name="Slot2Selector"
                                     GroupName="ActiveSlot"
                                     Content="Slot 2"/>
                    </GroupBox.Header>

                    <TextBlock Margin="10"
                               Text="Custom Hairstyle 2"/>
                </GroupBox>

                <GroupBox Margin="0,0,0,10">
                    <GroupBox.Header>
                        <RadioButton x:Name="Slot3Selector"
                                     GroupName="ActiveSlot"
                                     Content="Slot 3"/>
                    </GroupBox.Header>

                    <TextBlock Margin="10"
                               Text="Custom Hairstyle 3"/>
                </GroupBox>

                <GroupBox Margin="0,0,0,20">
                    <GroupBox.Header>
                        <RadioButton x:Name="Slot4Selector"
                                     GroupName="ActiveSlot"
                                     Content="Slot 4"/>
                    </GroupBox.Header>

                    <TextBlock Margin="10"
                               Text="Custom Hairstyle 4"/>
                </GroupBox>

                <Button x:Name="ExportButton"
                        Height="40"
                        Content="Export"
                        Click="ExportButton_Click"/>

            </StackPanel>

        </ScrollViewer>

        <!-- ===================================================== -->
        <!-- CENTER COLUMN -->
        <!-- ===================================================== -->

        <GroupBox x:Name="PreviewGroup"
                  Grid.Column="1"
                  Header="Live Preview — Slot 1"
                  Margin="10,0">

            <Grid>

                <Viewbox Stretch="Uniform"
                         RenderOptions.BitmapScalingMode="NearestNeighbor">

                    <Grid Width="320"
                          Height="320">

                        <Image x:Name="PreviewBack"/>
                        <Image x:Name="PreviewBody"/>
                        <Image x:Name="PreviewBase"/>
                        <Image x:Name="PreviewBangs"/>

                    </Grid>

                </Viewbox>

            </Grid>

        </GroupBox>

        <!-- ===================================================== -->
        <!-- RIGHT COLUMN -->
        <!-- ===================================================== -->

        <GroupBox Grid.Column="2"
                  Header="Hair Composer"
                  Margin="20,0,0,0">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel Margin="10">

                    <TextBlock Text="Bangs"
                               FontWeight="Bold"/>

                    <ComboBox x:Name="ComposerBangs"
                              Margin="0,5,0,5"/>

                    <TextBlock Text="Color"/>

                    <StackPanel Orientation="Horizontal"
                                Margin="0,5,0,20">

                        <ComboBox x:Name="ComposerBangsColor"
                                  Width="120"
                                  Margin="0,0,8,0"/>

                        <ComboBox x:Name="ComposerBangsShade"
                                  Width="90"/>

                    </StackPanel>

                    <TextBlock Text="Base Hair"
                               FontWeight="Bold"/>

                    <ComboBox x:Name="ComposerBase"
                              Margin="0,5,0,5"/>

                    <TextBlock Text="Color"/>

                    <StackPanel Orientation="Horizontal"
                                Margin="0,5,0,20">

                        <ComboBox x:Name="ComposerBaseColor"
                                  Width="120"
                                  Margin="0,0,8,0"/>

                        <ComboBox x:Name="ComposerBaseShade"
                                  Width="90"/>

                    </StackPanel>

                    <TextBlock Text="Back Hair"
                               FontWeight="Bold"/>

                    <ComboBox x:Name="ComposerBack"
                              Margin="0,5,0,5"/>

                    <TextBlock Text="Color"/>

                    <StackPanel Orientation="Horizontal"
                                Margin="0,5,0,20">

                        <ComboBox x:Name="ComposerBackColor"
                                  Width="120"
                                  Margin="0,0,8,0"/>

                        <ComboBox x:Name="ComposerBackShade"
                                  Width="90"/>

                    </StackPanel>

                </StackPanel>

            </ScrollViewer>

        </GroupBox>

    </Grid>

</Window>