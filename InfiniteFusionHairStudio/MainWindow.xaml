<Window x:Class="InfiniteFusionHairStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Infinite Fusion Hair Studio"
        WindowState="Maximized"
        MinWidth="1200"
        MinHeight="700">

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ===================================================== -->
        <!-- LEFT COLUMN -->
        <!-- ===================================================== -->

        <ScrollViewer Grid.Column="0"
                      VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="0,0,20,0">

                <TextBlock Text="Replace Hairstyle"
                           FontWeight="Bold"/>

                <ComboBox x:Name="ReplaceHairComboBox"
                          Margin="0,5,0,20"/>

                <!-- Slot 1 -->

                <GroupBox Margin="0,0,0,10">

                    <GroupBox.Header>
                        <RadioButton x:Name="Slot1Selector"
                                     GroupName="ActiveSlot"
                                     Content="Slot 1"
                                     IsChecked="True"/>
                    </GroupBox.Header>

                    <StackPanel Margin="10">

                        <TextBlock Text="Hair"/>

                        <ComboBox x:Name="Slot1Hair"/>

                        <TextBlock Text="Color"
                                   Margin="0,10,0,0"/>

                        <ComboBox x:Name="Slot1Color"/>

                    </StackPanel>

                </GroupBox>

                <!-- Slot 2 -->

                <GroupBox Margin="0,0,0,10">

                    <GroupBox.Header>
                        <RadioButton x:Name="Slot2Selector"
                                     GroupName="ActiveSlot"
                                     Content="Slot 2"/>
                    </GroupBox.Header>

                    <StackPanel Margin="10">

                        <TextBlock Text="Hair"/>

                        <ComboBox x:Name="Slot2Hair"/>

                        <TextBlock Text="Color"
                                   Margin="0,10,0,0"/>

                        <ComboBox x:Name="Slot2Color"/>

                    </StackPanel>

                </GroupBox>

                <!-- Slot 3 -->

                <GroupBox Margin="0,0,0,10">

                    <GroupBox.Header>
                        <RadioButton x:Name="Slot3Selector"
                                     GroupName="ActiveSlot"
                                     Content="Slot 3"/>
                    </GroupBox.Header>

                    <StackPanel Margin="10">

                        <TextBlock Text="Hair"/>

                        <ComboBox x:Name="Slot3Hair"/>

                        <TextBlock Text="Color"
                                   Margin="0,10,0,0"/>

                        <ComboBox x:Name="Slot3Color"/>

                    </StackPanel>

                </GroupBox>

                <!-- Slot 4 -->

                <GroupBox Margin="0,0,0,20">

                    <GroupBox.Header>
                        <RadioButton x:Name="Slot4Selector"
                                     GroupName="ActiveSlot"
                                     Content="Slot 4"/>
                    </GroupBox.Header>

                    <StackPanel Margin="10">

                        <TextBlock Text="Hair"/>

                        <ComboBox x:Name="Slot4Hair"/>

                        <TextBlock Text="Color"
                                   Margin="0,10,0,0"/>

                        <ComboBox x:Name="Slot4Color"/>

                    </StackPanel>

                </GroupBox>

                <Button x:Name="ExportButton"
                        Height="40"
                        Content="Export"
                        Click="ExportButton_Click"/>

            </StackPanel>

        </ScrollViewer>

        <!-- ===================================================== -->
        <!-- CENTER COLUMN -->
        <!-- ===================================================== -->

        <GroupBox x:Name="PreviewGroup"
                  Grid.Column="1"
                  Header="Live Preview — Slot 1"
                  Margin="10,0">

            <Grid>

                <Viewbox Stretch="Uniform"
                         RenderOptions.BitmapScalingMode="NearestNeighbor">

                    <Grid Width="320"
                          Height="320">

                        <Image x:Name="PreviewBody"/>

                        <Image x:Name="PreviewHair"/>

                    </Grid>

                </Viewbox>

            </Grid>

        </GroupBox>

        <!-- ===================================================== -->
        <!-- RIGHT COLUMN -->
        <!-- ===================================================== -->

        <GroupBox Grid.Column="2"
                  Header="Hair Composer"
                  Margin="20,0,0,0">

            <StackPanel Margin="10">

                <TextBlock Text="Coming in Version 2"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <Button Content="Bangs"
                        IsEnabled="False"
                        Margin="0,0,0,8"/>

                <Button Content="Side Hair"
                        IsEnabled="False"
                        Margin="0,0,0,8"/>

                <Button Content="Back Hair"
                        IsEnabled="False"
                        Margin="0,0,0,8"/>

                <Button Content="Ponytail"
                        IsEnabled="False"
                        Margin="0,0,0,8"/>

                <Button Content="Cowlick"
                        IsEnabled="False"
                        Margin="0,0,0,8"/>

                <Button Content="Accessories"
                        IsEnabled="False"/>

            </StackPanel>

        </GroupBox>

    </Grid>

</Window>