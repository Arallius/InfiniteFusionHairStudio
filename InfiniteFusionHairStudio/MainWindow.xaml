<Window x:Class="InfiniteFusionHairStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Infinite Fusion Hair Studio"
        Height="700"
        Width="420">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <TextBlock Text="Replace Hairstyle"
                       FontWeight="Bold"/>

            <ComboBox x:Name="ReplaceHairComboBox"
                      Margin="0,5,0,20"/>

            <!-- Slot 1 -->
            <GroupBox Header="Slot 1" Margin="0,0,0,10">
                <StackPanel Margin="10">
                    <TextBlock Text="Hair"/>
                    <ComboBox x:Name="Slot1Hair"/>

                    <TextBlock Text="Color" Margin="0,10,0,0"/>
                    <ComboBox x:Name="Slot1Color"/>
                </StackPanel>
            </GroupBox>

            <!-- Slot 2 -->
            <GroupBox Header="Slot 2" Margin="0,0,0,10">
                <StackPanel Margin="10">
                    <TextBlock Text="Hair"/>
                    <ComboBox x:Name="Slot2Hair"/>

                    <TextBlock Text="Color" Margin="0,10,0,0"/>
                    <ComboBox x:Name="Slot2Color"/>
                </StackPanel>
            </GroupBox>

            <!-- Slot 3 -->
            <GroupBox Header="Slot 3" Margin="0,0,0,10">
                <StackPanel Margin="10">
                    <TextBlock Text="Hair"/>
                    <ComboBox x:Name="Slot3Hair"/>

                    <TextBlock Text="Color" Margin="0,10,0,0"/>
                    <ComboBox x:Name="Slot3Color"/>
                </StackPanel>
            </GroupBox>

            <!-- Slot 4 -->
            <GroupBox Header="Slot 4" Margin="0,0,0,20">
                <StackPanel Margin="10">
                    <TextBlock Text="Hair"/>
                    <ComboBox x:Name="Slot4Hair"/>

                    <TextBlock Text="Color" Margin="0,10,0,0"/>
                    <ComboBox x:Name="Slot4Color"/>
                </StackPanel>
            </GroupBox>

            <Button x:Name="ExportButton"
        Content="Export"
        Height="40"
        Click="ExportButton_Click"/>

        </StackPanel>
    </ScrollViewer>
</Window>